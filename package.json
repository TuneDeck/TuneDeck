{
  "name": "tunedeck",
  "version": "0.7.0",
  "description": "Modern TuneDeck desktop prototype with queue, playlists, song pages, artist pages and settings using an external PHP API.",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist:win": "electron-builder --win portable nsis",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "dependencies": {
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.schmittdev.tunedeck",
    "productName": "TuneDeck",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "build/icon.png"
    },
    "icon": "build/icon.png"
  }
}