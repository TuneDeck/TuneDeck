{
  "name": "ncs-electron-prototype",
  "version": "0.4.0",
  "description": "Modern NCS desktop prototype with queue, autoplay, search and local playlists using an external PHP API.",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist:win": "electron-builder --win portable nsis",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "dependencies": {
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.schmittdev.ncsplayer",
    "productName": "NCS Player Prototype",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music"
    }
  }
}